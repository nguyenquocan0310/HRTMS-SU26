{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER;Database=YOUR_DB;uid=YOUR_UID;pwd=YOUR_PWD;TrustServerCertificate=True;"
  },
  "JwtSettings": {
    "SecretKey": "CHANGE_THIS_TO_A_LONG_SECRET_KEY_AT_LEAST_32_CHARS",
    "Issuer": "HRTMS",
    "Audience": "HRTMS-Client",
    "ExpiryMinutes": 60
  }
}
